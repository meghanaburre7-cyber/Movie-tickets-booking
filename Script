<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Movie Ticket Booking</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: Arial, sans-serif; }
    body { background: #0f172a; color: #fff; padding: 20px; }
 .hidden { display: none; }
 .container { max-width: 500px; margin: 50px auto; background: #1e293b; padding: 30px; border-radius: 10px; }
    h1 { text-align: center; color: #ef4444; margin-bottom: 20px; }
    input, select, button { width: 100%; padding: 12px; margin: 8px 0; border: none; border-radius: 6px; font-size: 15px; }
    input, select { background: #0f172a; color: white; border: 1px solid #334155; }
    button { background: #ef4444; color: white; font-weight: bold; cursor: pointer; }
    button:hover { background: #dc2626; }
    button:active { transform: scale(0.98); }
 .link { text-align: center; margin-top: 15px; color: #94a3b8; }
 .link span { color: #3b82f6; cursor: pointer; text-decoration: underline; font-weight: bold; }
 .header { background: #1e293b; padding: 15px; display: flex; justify-content: space-between; align-items: center; margin: -20px -20px 20px -20px; }
 .logo { font-size: 20px; font-weight: bold; color: #ef4444; }
 .movies { display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; margin: 20px 0; }
 .movie { background: #0f172a; padding: 20px; border-radius: 8px; text-align: center; cursor: pointer; border: 2px solid transparent; }
 .movie:hover { border-color: #ef4444; }
 .movie.active { border-color: #22c55e; background: #1a2e1a; }
 .emoji { font-size: 40px; margin-bottom: 10px; }
 .seats { display: grid; grid-template-columns: repeat(8, 1fr); gap: 5px; margin: 15px 0; }
 .seat { aspect-ratio: 1; background: #334155; border-radius: 4px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 10px; }
 .seat.selected { background: #22c55e; }
 .seat.booked { background: #ef4444; cursor: not-allowed; }
 .total { background: #0f172a; padding: 15px; border-radius: 6px; margin: 15px 0; text-align: center; font-size: 18px; font-weight: bold; }
 .success { background: #22c55e; padding: 15px; border-radius: 6px; text-align: center; margin-top: 15px; }
  </style>
</head>
<body>

  <!-- Signup - Default Page -->
  <div id="signupBox" class="container">
    <h1>🎬 Sign Up</h1>
    <input type="text" id="signupName" placeholder="Name">
    <input type="email" id="signupEmail" placeholder="Email">
    <input type="password" id="signupPass" placeholder="Password">
    <button onclick="signup()">Sign Up</button>
    <div class="link">Already account unda? <span onclick="showLogin()">Login</span></div>
  </div>

  <!-- Login -->
  <div id="loginBox" class="container hidden">
    <h1>🎬 Login</h1>
    <input type="email" id="loginEmail" placeholder="Email">
    <input type="password" id="loginPass" placeholder="Password">
    <button onclick="login()">Login</button>
    <div class="link">Account ledu? <span onclick="showSignup()">Sign Up</span></div>
  </div>

  <!-- Booking -->
  <div id="bookingBox" class="hidden">
    <div class="header">
      <div class="logo">🎬 BookMyShow</div>
      <div>
        <span id="userName"></span>
        <button onclick="logout()" style="width: auto; padding: 8px 16px; margin-left: 10px;">Logout</button>
      </div>
    </div>

    <div class="container" style="max-width: 800px;">
      <h2>Select Movie</h2>
      <div class="movies" id="moviesList"></div>

      <div id="bookingDetails" class="hidden">
        <h3 id="selectedMovie" style="margin: 20px 0;"></h3>
        
        <select id="theatre">
          <option>PVR: Forum Mall</option>
          <option>INOX: GVK One</option>
          <option>AMB Cinemas</option>
        </select>

        <input type="date" id="date">
        
        <select id="time">
          <option>10:00 AM</option>
          <option>1:00 PM</option>
          <option>4:00 PM</option>
          <option>7:00 PM</option>
          <option>10:00 PM</option>
        </select>

        <h3 style="margin: 20px 0 10px 0;">Select Seats</h3>
        <div class="seats" id="seatsGrid"></div>

        <div class="total">Total: ₹<span id="total">0</span></div>
        <button onclick="bookNow()">Book Now</button>
        <div id="msg"></div>
      </div>
    </div>
  </div>

  <script>
    let currentUser = null;
    let selectedMovie = null;
    let selectedSeats = [];
    
    window.onload = function() {
      currentUser = JSON.parse(localStorage.getItem('currentUser'));
      if(currentUser) {
        showBooking();
      } else {
        showSignup(); // Direct Sign Up page
      }
      document.getElementById('date').min = new Date().toISOString().split('T')[0];
      document.getElementById('date').value = new Date().toISOString().split('T')[0];
    }

    function showLogin() {
      document.getElementById('loginBox').classList.remove('hidden');
      document.getElementById('signupBox').classList.add('hidden');
      document.getElementById('bookingBox').classList.add('hidden');
    }

    function showSignup() {
      document.getElementById('loginBox').classList.add('hidden');
      document.getElementById('signupBox').classList.remove('hidden');
      document.getElementById('bookingBox').classList.add('hidden');
    }

    function showBooking() {
      document.getElementById('loginBox').classList.add('hidden');
      document.getElementById('signupBox').classList.add('hidden');
      document.getElementById('bookingBox').classList.remove('hidden');
      document.getElementById('userName').innerText = 'Hi, ' + currentUser.name;
      loadMovies();
    }

    function signup() {
      const name = document.getElementById('signupName').value.trim();
      const email = document.getElementById('signupEmail').value.trim();
      const pass = document.getElementById('signupPass').value;
      
      if(!name ||!email ||!pass) {
        alert('Anni fields fill chey');
        return;
      }
      
      let users = JSON.parse(localStorage.getItem('users')) || [];
      if(users.find(u => u.email === email)) {
        alert('Email already exists. Login avvu.');
        showLogin();
        return;
      }
      
      const newUser = {name, email, pass};
      users.push(newUser);
      localStorage.setItem('users', JSON.stringify(users));
      localStorage.setItem('currentUser', JSON.stringify(newUser));
      currentUser = newUser;
      alert('Signup success! Welcome ' + name);
      showBooking();
    }

    function login() {
      const email = document.getElementById('loginEmail').value.trim();
      const pass = document.getElementById('loginPass').value;
      
      if(!email ||!pass) {
        alert('Email and Password enter chey');
        return;
      }
      
      const users = JSON.parse(localStorage.getItem('users')) || [];
      const user = users.find(u => u.email === email && u.pass === pass);
      
      if(user) {
        localStorage.setItem('currentUser', JSON.stringify(user));
        currentUser = user;
        document.getElementById('loginEmail').value = '';
        document.getElementById('loginPass').value = '';
        showBooking();
      } else {
        alert('Invalid email or password');
      }
    }

    function logout() {
      localStorage.removeItem('currentUser');
      location.reload();
    }

    function loadMovies() {
      const movies = [
        {title: "Salaar", emoji: "⚔️"},
        {title: "Jawan", emoji: "🔥"},
        {title: "Leo", emoji: "🦁"},
        {title: "Devara", emoji: "🌊"}
      ];
      
      const list = document.getElementById('moviesList');
      list.innerHTML = '';
      movies.forEach(m => {
        const div = document.createElement('div');
        div.className = 'movie';
        div.innerHTML = `<div class="emoji">${m.emoji}</div><div>${m.title}</div>`;
        div.onclick = () => selectMovie(m, div);
        list.appendChild(div);
      });
    }

    function selectMovie(movie, el) {
      document.querySelectorAll('.movie').forEach(m => m.classList.remove('active'));
      el.classList.add('active');
      selectedMovie = movie;
      document.getElementById('selectedMovie').innerText = 'Booking: ' + movie.title;
      document.getElementById('bookingDetails').classList.remove('hidden');
      loadSeats();
    }

    function loadSeats() {
      const grid = document.getElementById('seatsGrid');
      grid.innerHTML = '';
      selectedSeats = [];
      updateTotal();
      
      const booked = [5, 12, 18, 23, 30];
      
      for(let i = 1; i <= 32; i++) {
        const seat = document.createElement('div');
        seat.className = 'seat';
        seat.innerText = i;
        
        if(booked.includes(i)) {
          seat.classList.add('booked');
        } else {
          seat.onclick = () => toggleSeat(i, seat);
        }
        grid.appendChild(seat);
      }
    }

    function toggleSeat(num, el) {
      if(el.classList.contains('selected')) {
        el.classList.remove('selected');
        selectedSeats = selectedSeats.filter(s => s!== num);
      } else {
        if(selectedSeats.length >= 6) {
          alert('Max 6 seats');
          return;
        }
        el.classList.add('selected');
        selectedSeats.push(num);
      }
      updateTotal();
    }

    function updateTotal() {
      document.getElementById('total').innerText = selectedSeats.length * 200;
    }

    function bookNow() {
      if(!selectedMovie) {
        alert('Movie select chey');
        return;
      }
      if(selectedSeats.length === 0) {
        alert('Seat select chey');
        return;
      }
      
      const bookingId = 'BMS' + Date.now();
      const msg = document.getElementById('msg');
      msg.className = 'success';
      msg.innerHTML = `✅ Booked!<br>ID: ${bookingId}<br>Movie: ${selectedMovie.title}<br>Seats: ${selectedSeats.join(', ')}<br>Total: ₹${selectedSeats.length * 200}`;
      
      setTimeout(() => {
        msg.innerHTML = '';
        msg.className = '';
        loadSeats();
      }, 4000);
    }
  </script>
</body>
</html>
